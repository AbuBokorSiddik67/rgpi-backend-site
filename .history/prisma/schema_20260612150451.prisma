generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
datasource db {
  provider = "postgresql" // অথবা "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ইন্সটিটিউটের বিভিন্ন রোল (Enum)
enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  STAFF
}

// মেইন ইউজার টেবিল ডিজাইন
model User {
  id        String   @id @default(uuid()) // সিকিউরিটির জন্য আমরা আইডি হিসেবে UUID ব্যবহার করব
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)    // নতুন কেউ অ্যাকাউন্ট খুললে ডিফল্ট রোল হবে STUDENT
  isActive  Boolean  @default(true)       // কোনো অ্যাকাউন্ট সাসপেন্ড করার জন্য অপশন
  createdAt DateTime @default(now())      // অ্যাকাউন্ট খোলার সময়
  updatedAt DateTime @updatedAt           // অ্যাকাউন্ট আপডেট করার সময়

  @@map("users") // ডাটাবেজে টেবিলের নাম ছোট হাতের 'users' হিসেবে জমা হবে
}