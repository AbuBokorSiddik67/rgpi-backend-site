# --- Stage 1: Build Stage ---
FROM node:20-alpine AS builder

WORKDIR /app

# শুধুমাত্র প্যাকেজ ফাইলগুলো আগে কপি করছি (ক্যাশিং সুবিধার জন্য)
COPY package*.json ./
COPY prisma ./prisma/

# ডিপেন্ডেন্সি ইনস্টল করা
RUN npm ci

# আপনার প্রিজমার নতুন আর্কিটেকচার অনুযায়ী ক্লায়েন্ট জেনারেট করা
RUN npx prisma generate

# বাকি সব সোর্স কোড কপি করা
COPY . .

# টাইপস্ক্রিপ্ট কোড বিল্ড করে 'dist' ফোল্ডারে জাভাস্ক্রিপ্ট জেনারেট করা
RUN npm run build

# অপ্রয়োজনীয় দেব-ডিপেন্ডেন্সি মুছে শুধু প্রোডাকশন প্যাকেজ রাখা
RUN npm prune --production


# --- Stage 2: Run Stage (একেবারে লাইটওয়েট প্রোডাকশন ইমেজ) ---
FROM node:20-alpine

WORKDIR /app

# প্রথম স্টেজ থেকে শুধুমাত্র প্রয়োজনীয় ফাইলগুলো কপি করে আনা
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/generated ./generated
COPY --from=builder /app/prisma ./prisma

EXPOSE 5000

# অ্যাপ রান করার কমান্ড
CMD ["npm", "run", "start"]