{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    // "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*",
    "generated/**/*",
    
  ],
  "exclude": ["node_modules", "dist"]
}